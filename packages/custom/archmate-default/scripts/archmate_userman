#!/bin/bash

#=======================================================================

help_msg(){
	echo -e "usage: archmate_userman [ add | del ] [USER_NAME]"
}

#=======================================================================

if [ $UID != 0 ];then
	echo -e "This script must run as root"
	exit
fi

if [ -z ${1} ] || [ -z ${2} ];then
	help_msg
	exit
fi

#=======================================================================

# export user defined things

export MODE=${1}
export NAME=${2}

if [ "$MODE" == "add" ];then
	useradd -m -g users -G wheel,storage,power,vboxsf,lp -s /bin/bash -c "$NAME" $NAME
	passwd -d $NAME
	archmate_userset $NAME

	echo "
[User]
Language=en_US.utf8
XSession=mate
SystemAccount=false
	" > /var/lib/AccountsService/users/$NAME

elif [ "$MODE" == "del" ];then
	rm -f /var/lib/AccountsService/users/$NAME
	userdel $NAME

else
	help_msg

fi

