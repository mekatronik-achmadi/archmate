#!/bin/bash

if [ $UID != 0 ];then
	echo -e "This script must run as root"
	exit
fi

if [ -z $1 ];then
	echo -e "usage: archmate_autologin username"
	exit
fi

echo -e "[Seat:*]
pam-service=lightdm
pam-autologin-service=lightdm-autologin
allow-guest=false
session-wrapper=/etc/lightdm/Xsession
greeter-session=lightdm-gtk-greeter
autologin-user-timeout=0
autologin-session=mate" > /etc/lightdm/lightdm.conf

username=$1

groupadd -r autologin
gpasswd -a $username autologin

echo -e "autologin-user=$username" >> /etc/lightdm/lightdm.conf
