systemd_session() {
	ln -sf /usr/share/anbox-helper/anbox.service /usr/lib/systemd/user/anbox-session-manager.service
	ln -sf /usr/share/anbox-helper/anbox.network /usr/lib/systemd/network/80-anbox-bridge.network
}

remove_menu() {
	rm -f /usr/share/applications/anbox.desktop
	rm -f /usr/share/applications/anbox-bridge.desktop
}

after_install() {
	systemd_session
	remove_menu
}

post_install() {
	after_install
}

post_upgrade() {
	after_install
}
